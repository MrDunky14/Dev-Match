# ── Database ──────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI)
# Use the "Transaction" pooler URI (port 6543) for serverless/short connections
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Auth ──────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-64-char-string

# ── GitHub API (optional — boosts rate limit from 60 to 5000 req/hr) ──
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ── CORS Origins (comma-separated, defaults shown) ───────
# CORS_ORIGINS=https://dev-match-tau.vercel.app,http://localhost:5173
